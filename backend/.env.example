APP_NAME=OMCLTA
APP_ENV=production
APP_KEY=base64:GENERATE_KEY_WITH_php_artisan_key_generate
APP_DEBUG=false
APP_URL=http://localhost:8000

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=omclta
DB_USERNAME=postgres
DB_PASSWORD=secret_password_change_me

BROADCAST_DRIVER=redis
CACHE_DRIVER=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis

REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=465
MAIL_USERNAME=your_mailtrap_user
MAIL_PASSWORD=your_mailtrap_pass
MAIL_FROM_ADDRESS=noreply@omclta.com
MAIL_FROM_NAME=OMCLTA

JWT_SECRET=your_jwt_secret_key_change_me
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_TTL=480
JWT_REFRESH_TOKEN_TTL=43200

IP_GEOLOCATION_API=ip-api.com
IP_GEOLOCATION_CACHE_TTL=3600

AUDIT_ASYNC=false

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
